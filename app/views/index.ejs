<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>スケジュール調整</title>
    <style>
        body { font-family: sans-serif; padding: 20px; background-color: #f4f6f8; }


       .container { 
            /* 幅の制限をなくし、画面幅に合わせる（余白はpaddingで確保） */
            width: 100%; 
            margin: 0 auto; 
            background: white; 
            padding: 20px; 
            border-radius: 8px; 
            /* はみ出さないように設定 */
            box-sizing: border-box; 
        }
        
        /* 表を囲むスクロール用エリア */
        .table-wrapper {
            width: 100%;
            overflow-x: auto;
            margin-top: 20px;
        }

        table { 
            border-collapse: collapse; 
        }

        th, td { 
            border: 1px solid #ddd; 
            padding: 5px; 
            text-align: center;
            
            min-width: 80px;
            white-space: nowrap;
        }
        th:first-child, td:first-child {
            min-width: 120px;
        }

        th { background-color: #5865F2; color: white; position: sticky; left: 0; }
        
        .count-ok { color: #2e7d32; font-weight: bold; font-size: 1.2em; }
        .count-zero { color: #c62828; font-weight: bold; }
        
        /* 記号ごとの色分け */
        .mark-〇 { color: #2e7d32; }
        .mark-△ { color: #f9a825; }
        .mark-▽ { color: #f9a825; }
        .mark-□ { color: #1976d2; font-weight: bold; }
        .mark-× { color: #c62828; }
    </style>
</head>
<body>
    <div class="container">
        <h1>📅 日程調整状況</h1>
        
        <% if (items && items.length > 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>日付</th>
                        <th>空き人数</th>
                        <% items[0].users.forEach(function(user) { %>
                            <th><%= user %></th>
                        <% }); %>
                    </tr>
                </thead>
                <tbody>
                    <% items.forEach(function(item) { %>
                        <tr>
                            <td><%= item.date %></td>
                            
                            <td class="<%= item.count > 0 ? 'count-ok' : 'count-zero' %>">
                                <%= item.count %>人
                            </td>

                            <% item.users.forEach(function(user) { %>
                                <% const mark = item.details[user]; %>
                                <td class="mark-<%= mark %>"><%= mark || '-' %></td>
                            <% }); %>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p>データがありません。</p>
        <% } %>
    </div>
</body>
</html>